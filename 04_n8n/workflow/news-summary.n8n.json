    {
      "id": "11f58a2b-845c-4340-b780-7c7f36bd0a26",
      "name": "OpenAI 요약",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        120
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"gpt-4o-mini\", \"temperature\": 0.3, \"max_tokens\": 300, \"messages\": [ { \"role\": \"system\", \"content\": \"당신은 IT/기술 뉴스 요약 전문가입니다. 주어진 기사를 한국어로 3줄 이내, 각 줄을 하이픈(-)으로 시작하는 불릿으로 요약하세요. 그리고 마지막 줄에 sentiment: 긍정|중립|부정 중 하나로 기사 논조의 감성을 표기하세요. 과장이나 추측 없이 사실만 담습니다.\" }, { \"role\": \"user\", \"content\": $('주제 필터').item.json.promptUser } ] } }}",
        "options": {}
      },
      "credentials": {
        "openAiApi": {
          "id": "REPLACE_WITH_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI account"
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "notes": "기사 1건당 1회 호출(재시도 제외). gpt-4o-mini, 3줄 + 감성."
    },
    {
      "id": "d0f007c5-62df-4126-adff-803f7ae38004",
      "name": "요약 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        120
      ],
      "parameters": {
        "jsCode": "// [요약 파싱] OpenAI 응답에서 3줄 요약과 감성 태그 추출\nconst res = $input.first().json;\nconst content = (res.choices && res.choices[0] && res.choices[0].message && res.choices[0].message.content) || '';\nlet sentiment = '중립';\nconst m = content.match(/sentiment\\s*[:：]\\s*(긍정|부정|중립)/i);\nif (m) { sentiment = m[1]; }\nconst lines = content.split('\\n').map(function (l) { return l.trim(); }).filter(function (l) { return l.indexOf('-') === 0; });\nlet summary = lines.slice(0, 3).join('\\n');\nif (!summary) { summary = content.replace(/sentiment\\s*[:：].*$/im, '').trim(); }\nreturn [{ json: { summary: summary, sentiment: sentiment } }];"
      },
      "notes": "응답에서 3줄 요약/감성 분리."
    },
