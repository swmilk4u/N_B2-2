    {
      "id": "216a4629-4969-4904-90c8-ada6abd25ce5",
      "name": "RSS 수집 (TechCrunch)",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1.1,
      "position": [
        0,
