# ─────────────────────────────────────────────────────────────
# 환경 변수 예시 (마스킹본)
# 실제 키는 이 파일이 아니라 n8n Credentials 또는 .env(추적 제외)에만 저장하세요.
# 복사: cp .env.example .env  → 실제 값 입력 후 사용
# ─────────────────────────────────────────────────────────────

# OpenAI API Key (요약/감성)  형식: sk-...
OPENAI_API_KEY=sk-****************************************

# Notion Internal Integration Token  형식: secret_... 또는 ntn_...
NOTION_API_TOKEN=ntn_********************************************

# 대상 Notion 데이터베이스 ID (공개 식별자라 마스킹 불필요)
NOTION_DATABASE_ID=99f64246-aa35-4575-abd7-73c223bb2fce

# 사용 모델 / 스케줄 (선택)
OPENAI_MODEL=gpt-4o-mini
SCHEDULE_CRON=0 9 * * *
TZ=Asia/Seoul
