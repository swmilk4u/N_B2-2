    },
    {
      "id": "4dc9eb6b-73f8-4962-a1fc-146c5d324aaa",
      "name": "주제 필터",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        320
      ],
      "parameters": {
        "jsCode": "// [주제 필터] AI 키워드로 거른 뒤 최신 1건만 선택\nconst KEYWORDS = ['ai','artificial intelligence','machine learning','deep learning','llm','gpt','openai','anthropic','gemini','copilot','neural','generative','인공지능','생성형','머신러닝','딥러닝'];\nconst TAG_RULES = [\n  { tag: '생성형AI', kw: ['generative','생성형'] },\n  { tag: 'LLM', kw: ['llm','gpt','language model'] },\n  { tag: '머신러닝', kw: ['machine learning','머신러닝'] },\n  { tag: '딥러닝', kw: ['deep learning','neural','딥러닝'] },\n  { tag: '반도체', kw: ['chip','gpu','semiconductor','nvidia','반도체'] },\n  { tag: '로봇', kw: ['robot','로봇'] },\n  { tag: 'AI', kw: ['ai','artificial intelligence','인공지능'] }\n];\nconst items = $input.all();\nconst matched = [];\nfor (const it of items) {\n  const j = it.json;\n  const title = (j.title || '').toString();\n  const rawContent = (j['content:encoded'] || j.content || j.contentSnippet || j.description || '').toString();\n  const cleanContent = rawContent.replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 4000);\n  const hay = (title + ' ' + cleanContent).toLowerCase();\n  if (!KEYWORDS.some(function (k) { return hay.indexOf(k) !== -1; })) { continue; }\n  const tags = TAG_RULES.filter(function (r) { return r.kw.some(function (k) { return hay.indexOf(k) !== -1; }); }).map(function (r) { return r.tag; });\n  const link = (j.link || j.guid || '').toString().split('?')[0];\n  const isoDate = j.isoDate || j.pubDate || null;\n  const promptUser = '제목: ' + title + '\\n\\n본문: ' + cleanContent;\n  matched.push({ title: title, link: link, isoDate: isoDate, source: 'TechCrunch', tags: tags.length ? tags : ['AI'], promptUser: promptUser });\n}\nmatched.sort(function (a, b) { return new Date(b.isoDate || 0) - new Date(a.isoDate || 0); });\nif (matched.length === 0) { return [{ json: { found: false } }]; }\nreturn [{ json: Object.assign({ found: true }, matched[0]) }];"
      },
      "notes": "AI 키워드 필터 + 최신 1건 선택. 0건이면 found:false."
    },
